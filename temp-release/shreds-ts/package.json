{
  "name": "shreds-ts-starter",
  "description": "Solana Shreds TypeScript Client",
  "version": "1.2.2",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "pnpm": ">=10",
    "npm": "please_use_pnpm_instead",
    "node": ">=22 <23 || >=24 <25",
    "version": "0.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ValidatorsDAO/solana-stream.git"
  },
  "bugs": {
    "url": "https://discord.gg/C7ZQSrCkYR"
  },
  "files": [
    "./*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "update:packages": "pnpm update --latest"
  },
  "dependencies": {
    "@solana/kit": "6.10.0",
    "@validators-dao/solana-stream-sdk": "1.2.2",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "prettier": "3.8.4",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
