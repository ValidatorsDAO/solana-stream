# ⚠️ This is a sample. Copy to .env and fill in your values.
GRPC_ENDPOINT=https://grpc.erpc.global
X_TOKEN=YOUR_X_TOKEN
API_PORT=3000

# RPC: one of these (ERPC_API_KEY in .env.erpc is auto-loaded)
# SOLANA_RPC_ENDPOINT=https://edge.erpc.global?api-key=YOUR_KEY
# Or create .env.erpc with: ERPC_API_KEY=YOUR_KEY

# Optional: Discord webhook for create_pool notifications
WEBHOOK_URL=

# Optional: Bearer token for API authentication (all endpoints require it if set)
API_TOKEN=
